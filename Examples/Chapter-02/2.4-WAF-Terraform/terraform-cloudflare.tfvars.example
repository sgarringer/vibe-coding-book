# ============================================
# CLOUDFLARE TERRAFORM VARIABLES
# ============================================
# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars
# ============================================

# Cloudflare API Token
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.Firewall Services, Zone.Zone Settings, Zone.Zone
cloudflare_api_token = "your-api-token-here"

# Zone ID
# Find in: Cloudflare Dashboard → Select your domain → Overview (right sidebar)
zone_id = "your-zone-id-here"

# Domain
domain = "yourapp.com"

# Rate Limiting
rate_limit_login_threshold = 10   # 10 login attempts per minute per IP
rate_limit_api_threshold   = 100  # 100 API requests per minute per IP

# Bot Management
enable_bot_fight_mode = true

# Security Level
# Options: off, essentially_off, low, medium, high, under_attack
security_level = "medium"

# Geo-Blocking (Optional)
# Uncomment to enable
# blocked_countries = ["CN", "RU", "KP"]
blocked_countries = []
