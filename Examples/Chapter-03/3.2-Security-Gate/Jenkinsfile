// =============================================================================
// Jenkinsfile - Complete Security Gate
// Book Reference: Chapter 3, Section 3.2.1.2
// =============================================================================
// Features demonstrated:
//   - Quality gates with configurable thresholds
//   - Email notifications
//   - Slack integration
//   - SAST + dependency scanning
//   - Override mechanism for emergencies
// =============================================================================
//
// SETUP REQUIRED:
//   1. Install plugins: Pipeline, Email Extension, Slack Notification
//   2. Configure Slack in Jenkins: Manage Jenkins > Configure System > Slack
//   3. Add credentials:
//      - semgrep-app-token  : Semgrep Cloud Platform token (optional)
//      - security-gate-smtp : SMTP credentials for email notifications
//   4. Copy thresholds.yml to your repository root as security-thresholds.yml
//
// OVERRIDE MECHANISM:
//   Run the pipeline with parameter SECURITY_OVERRIDE=true
//   and provide SECURITY_OVERRIDE_REASON to bypass the gate.
//   The security team will be notified automatically.
// =============================================================================

pipeline {
    agent any

    // =========================================================================
    // Pipeline parameters
    // Allow manual override for emergency deployments
    // =========================================================================
    parameters {
        booleanParam(
            name:         'SECURITY_OVERRIDE',
            defaultValue: false,
            description:  'Emergency override - bypasses security gate. ' +
                          'Security team will be notified. ' +
                          'Requires SECURITY_OVERRIDE_REASON.'
        )
        string(
            name:         'SECURITY_OVERRIDE_REASON',
            defaultValue: '',
            description:  'Required when SECURITY_OVERRIDE=true. ' +
                          'Document why the security gate is being bypassed.'
        )
        choice(
            name:         'FORCE_PROFILE',
            choices:      ['auto', 'learning', 'warning', 'enforcement'],
            description:  'Force a specific threshold profile. ' +
                          '"auto" reads from security-thresholds.yml.'
        )
    }

    // =========================================================================
    // Environment variables
    // =========================================================================
    environment {
        // Notification targets
        SECURITY_EMAIL = 'security-team@yourcompany.com'
        DEV_EMAIL      = "${env.CHANGE_AUTHOR_EMAIL ?: 'dev-team@yourcompany.com'}"

        // Artifact paths
        SAST_RESULTS    = 'sast-results.json'
        TRIVY_RESULTS   = 'trivy-results.json'
        GATE_REPORT     = 'security-gate-report.json'
        THRESHOLDS_FILE = 'security-thresholds.yml'

        // Default thresholds (Table 3.4 enforcement profile)
        // Used if security-thresholds.yml is not present
        DEFAULT_SAST_CRITICAL_THRESHOLD = '0'
        DEFAULT_SAST_HIGH_THRESHOLD     = '3'
        DEFAULT_DEP_CRITICAL_THRESHOLD  = '0'
        DEFAULT_DEP_HIGH_THRESHOLD      = '5'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
        disableConcurrentBuilds()
        // Preserve stashes between stages for artifact passing
        preserveStashes(buildCount: 5)
    }

    stages {

        // =====================================================================
        // Stage 1: Checkout and validate override
        // =====================================================================
        stage('Checkout') {
            steps {
                checkout scm

                script {
                    // Capture git metadata
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()
                    env.GIT_BRANCH = sh(
                        script: 'git rev-parse --abbrev-ref HEAD',
                        returnStdout: true
                    ).trim()

                    // Validate override parameters
                    if (params.SECURITY_OVERRIDE) {
                        if (!params.SECURITY_OVERRIDE_REASON?.trim()) {
                            error(
                                "SECURITY_OVERRIDE_REASON is required " +
                                "when SECURITY_OVERRIDE=true. " +
                                "Document why the security gate is being bypassed."
                            )
                        }

                        echo "⚠️  EMERGENCY OVERRIDE ACTIVE"
                        echo "Reason: ${params.SECURITY_OVERRIDE_REASON}"

                        // Notify security team immediately
                        emailext(
                            subject: "🚨 Security Gate Override: " +
                                     "${env.JOB_NAME} #${env.BUILD_NUMBER}",
                            body: """
                                <h2>Security Gate Override Activated</h2>
                                <table>
                                    <tr><td><b>Job</b></td>
                                        <td>${env.JOB_NAME}</td></tr>
                                    <tr><td><b>Build</b></td>
                                        <td>#${env.BUILD_NUMBER}</td></tr>
                                    <tr><td><b>Branch</b></td>
                                        <td>${env.GIT_BRANCH}</td></tr>
                                    <tr><td><b>Author</b></td>
                                        <td>${env.GIT_AUTHOR}</td></tr>
                                    <tr><td><b>Reason</b></td>
                                        <td style="color:red">
                                            ${params.SECURITY_OVERRIDE_REASON}
                                        </td></tr>
                                    <tr><td><b>Build URL</b></td>
                                        <td><a href="${env.BUILD_URL}">
                                            ${env.BUILD_URL}
                                        </a></td></tr>
                                </table>
                                <p>A security review is required within 24 hours.</p>
                            """,
                            to:       env.SECURITY_EMAIL,
                            mimeType: 'text/html'
                        )
                    }
                }
            }
        }

        // =====================================================================
        // Stage 2: Load thresholds
        // Parse security-thresholds.yml and set pipeline-wide variables
        // =====================================================================
        stage('Load Thresholds') {
            steps {
                script {
                    // Install yq if not available
                    sh '''
                        if ! command -v yq &> /dev/null; then
                            wget -qO /usr/local/bin/yq \
                                https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64
                            chmod +x /usr/local/bin/yq
                        fi
                    '''

                    if (fileExists(env.THRESHOLDS_FILE)) {
                        echo "Loading thresholds from ${env.THRESHOLDS_FILE}"

                        // Determine profile
                        def profile = params.FORCE_PROFILE == 'auto'
                            ? sh(script: "yq '.active_profile' ${env.THRESHOLDS_FILE}",
                                 returnStdout: true).trim()
                            : params.FORCE_PROFILE

                        // Determine environment override based on branch
                        def basePath = ".profiles.${profile}"
                        def branch   = env.GIT_BRANCH

                        if (branch ==~ /^(main|master|release\/.*)$/) {
                            basePath = ".environment_overrides.production"
                            echo "Using production environment override"
                        } else if (branch ==~ /^(staging|develop)$/) {
                            basePath = ".environment_overrides.staging"
                            echo "Using staging environment override"
                        } else if (branch ==~ /^(feature|fix|hotfix)\/.+$/) {
                            basePath = ".environment_overrides.feature"
                            echo "Using feature environment override"
                        }

                        // Read thresholds
                        env.ACTIVE_PROFILE = profile
                        env.SAST_CRITICAL_THRESHOLD = sh(
                            script: "yq '${basePath}.sast.critical.threshold' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.SAST_CRITICAL_ACTION = sh(
                            script: "yq '${basePath}.sast.critical.action' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.SAST_HIGH_THRESHOLD = sh(
                            script: "yq '${basePath}.sast.high.threshold' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.SAST_HIGH_ACTION = sh(
                            script: "yq '${basePath}.sast.high.action' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.SAST_MEDIUM_ACTION = sh(
                            script: "yq '${basePath}.sast.medium.action' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.DEP_CRITICAL_THRESHOLD = sh(
                            script: "yq '${basePath}.dependency.critical.threshold' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.DEP_CRITICAL_ACTION = sh(
                            script: "yq '${basePath}.dependency.critical.action' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.DEP_HIGH_THRESHOLD = sh(
                            script: "yq '${basePath}.dependency.high.threshold' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()
                        env.DEP_HIGH_ACTION = sh(
                            script: "yq '${basePath}.dependency.high.action' " +
                                    "${env.THRESHOLDS_FILE}",
                            returnStdout: true
                        ).trim()

                    } else {
                        echo "⚠️  ${env.THRESHOLDS_FILE} not found. Using enforcement defaults."
                        env.ACTIVE_PROFILE          = 'default'
                        env.SAST_CRITICAL_THRESHOLD = env.DEFAULT_SAST_CRITICAL_THRESHOLD
                        env.SAST_CRITICAL_ACTION    = 'break'
                        env.SAST_HIGH_THRESHOLD     = env.DEFAULT_SAST_HIGH_THRESHOLD
                        env.SAST_HIGH_ACTION        = 'break'
                        env.SAST_MEDIUM_ACTION      = 'warn'
                        env.DEP_CRITICAL_THRESHOLD  = env.DEFAULT_DEP_CRITICAL_THRESHOLD
                        env.DEP_CRITICAL_ACTION     = 'break'
                        env.DEP_HIGH_THRESHOLD      = env.DEFAULT_DEP_HIGH_THRESHOLD
                        env.DEP_HIGH_ACTION         = 'break'
                    }

                    echo """
                    ============================================
                    Security Gate Configuration
                    ============================================
                    Profile              : ${env.ACTIVE_PROFILE}
                    Branch               : ${env.GIT_BRANCH}
                    Override Active      : ${params.SECURITY_OVERRIDE}
                    --------------------------------------------
                    SAST Critical        : ${env.SAST_CRITICAL_ACTION} > ${env.SAST_CRITICAL_THRESHOLD}
                    SAST High            : ${env.SAST_HIGH_ACTION} > ${env.SAST_HIGH_THRESHOLD}
                    SAST Medium          : ${env.SAST_MEDIUM_ACTION}
                    Dep Critical         : ${env.DEP_CRITICAL_ACTION} > ${env.DEP_CRITICAL_THRESHOLD}
                    Dep High             : ${env.DEP_HIGH_ACTION} > ${env.DEP_HIGH_THRESHOLD}
                    ============================================
                    """
                }
            }
        }

        // =====================================================================
        // Stage 3: Parallel security scans
        // Run SAST and dependency scan simultaneously to minimize pipeline time
        // Principle: Minimize Friction (Section 3.1.1)
        // =====================================================================
        stage('Security Scans') {
            parallel {

                // -------------------------------------------------------------
                // SAST with Semgrep
                // -------------------------------------------------------------
                stage('SAST - Semgrep') {
                    agent {
                        docker {
                            image 'returntocorp/semgrep:latest'
                            reuseNode true
                        }
                    }
                    steps {
                        sh """
                            semgrep scan \\
                                --config=auto \\
                                --config=p/security-audit \\
                                --config=p/owasp-top-ten \\
                                --json \\
                                --output=${env.SAST_RESULTS} \\
                                --verbose \\
                                || true
                        """
                    }
                    post {
                        always {
                            stash name: 'sast-results',
                                  includes: "${env.SAST_RESULTS}"
                        }
                    }
                }

                // -------------------------------------------------------------
                // Dependency scan with Trivy
                // -------------------------------------------------------------
                stage('Dependencies - Trivy') {
                    agent {
                        docker {
                            image 'aquasec/trivy:latest'
                            reuseNode true
                            args '--entrypoint=""'
                        }
                    }
                    steps {
                        sh """
                            trivy fs \\
                                --format json \\
                                --output ${env.TRIVY_RESULTS} \\
                                --severity CRITICAL,HIGH,MEDIUM,LOW \\
                                --exit-code 0 \\
                                .
                        """
                    }
                    post {
                        always {
                            stash name: 'trivy-results',
                                  includes: "${env.TRIVY_RESULTS}"
                        }
                    }
                }
            }
        }

        // =====================================================================
        // Stage 4: Security Quality Gate
        // Evaluate all scan results against configured thresholds
        // Principle: Fail Fast (Section 3.1.1)
        // =====================================================================
        stage('Security Quality Gate') {
            steps {
                script {
                    // Retrieve stashed results
                    unstash 'sast-results'
                    unstash 'trivy-results'

                    // ---------------------------------------------------------
                    // Parse SAST results
                    // ---------------------------------------------------------
                    def sastCritical = sh(
                        script: """jq '[.results[] |
                            select(.extra.severity == "ERROR")] | length' \\
                            ${env.SAST_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    def sastHigh = sh(
                        script: """jq '[.results[] |
                            select(.extra.severity == "WARNING")] | length' \\
                            ${env.SAST_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    def sastMedium = sh(
                        script: """jq '[.results[] |
                            select(.extra.severity == "INFO")] | length' \\
                            ${env.SAST_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    // ---------------------------------------------------------
                    // Parse dependency results
                    // ---------------------------------------------------------
                    def depCritical = sh(
                        script: """jq '[.Results[].Vulnerabilities[]? |
                            select(.Severity == "CRITICAL")] | length' \\
                            ${env.TRIVY_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    def depHigh = sh(
                        script: """jq '[.Results[].Vulnerabilities[]? |
                            select(.Severity == "HIGH")] | length' \\
                            ${env.TRIVY_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    def depMedium = sh(
                        script: """jq '[.Results[].Vulnerabilities[]? |
                            select(.Severity == "MEDIUM")] | length' \\
                            ${env.TRIVY_RESULTS} 2>/dev/null || echo 0""",
                        returnStdout: true
                    ).trim().toInteger()

                    // Store counts for notifications
                    env.SAST_CRITICAL_COUNT = sastCritical.toString()
                    env.SAST_HIGH_COUNT     = sastHigh.toString()
                    env.SAST_MEDIUM_COUNT   = sastMedium.toString()
                    env.DEP_CRITICAL_COUNT  = depCritical.toString()
                    env.DEP_HIGH_COUNT      = depHigh.toString()
                    env.DEP_MEDIUM_COUNT    = depMedium.toString()

                    echo """
                    ============================================
                    Security Scan Results
                    ============================================
                    SAST Critical  : ${sastCritical}
                    SAST High      : ${sastHigh}
                    SAST Medium    : ${sastMedium}
                    Dep Critical   : ${depCritical}
                    Dep High       : ${depHigh}
                    Dep Medium     : ${depMedium}
                    ============================================
                    """

                    // ---------------------------------------------------------
                    // Evaluate thresholds
                    // ---------------------------------------------------------
                    def gateFailures  = []
                    def gateWarnings  = []
                    def overrideActive = params.SECURITY_OVERRIDE

                    // Helper closure to evaluate a single threshold
                    def evaluateThreshold = { count, threshold, action, label ->
                        if (count > threshold) {
                            def msg = "${label}: ${count} findings " +
                                      "(threshold: ${threshold})"
                            if (action == 'break' && !overrideActive) {
                                gateFailures << "❌ ${msg}"
                            } else {
                                gateWarnings << "⚠️  ${msg}"
                            }
                        }
                    }

                    // Evaluate each threshold (Table 3.4)
                    evaluateThreshold(
                        sastCritical,
                        env.SAST_CRITICAL_THRESHOLD.toInteger(),
                        env.SAST_CRITICAL_ACTION,
                        'SAST Critical'
                    )
                    evaluateThreshold(
                        sastHigh,
                        env.SAST_HIGH_THRESHOLD.toInteger(),
                        env.SAST_HIGH_ACTION,
                        'SAST High'
                    )
                    evaluateThreshold(
                        depCritical,
                        env.DEP_CRITICAL_THRESHOLD.toInteger(),
                        env.DEP_CRITICAL_ACTION,
                        'Dependency Critical'
                    )
                    evaluateThreshold(
                        depHigh,
                        env.DEP_HIGH_THRESHOLD.toInteger(),
                        env.DEP_HIGH_ACTION,
                        'Dependency High'
                    )

                    // Medium always warns per Table 3.4
                    if (sastMedium > 0) {
                        gateWarnings << "⚠️  SAST Medium: ${sastMedium} findings"
                    }
                    if (depMedium > 0) {
                        gateWarnings << "⚠️  Dependency Medium: ${depMedium} findings"
                    }

                    // ---------------------------------------------------------
                    // Print detailed findings for developer context
                    // Principle: Provide Context (Section 3.1.1)
                    // ---------------------------------------------------------
                    if (sastCritical > 0) {
                        echo "=== SAST Critical Findings ==="
                        sh """
                            jq -r '.results[] |
                                select(.extra.severity == "ERROR") |
                                "Rule: \\(.check_id)\\nFile: \\(.path):\\(.start.line)\\nMessage: \\(.extra.message)\\n"' \\
                                ${env.SAST_RESULTS} | head -50
                        """
                    }

                    if (depCritical > 0) {
                        echo "=== Dependency Critical Findings ==="
                        sh """
                            jq -r '.Results[].Vulnerabilities[]? |
                                select(.Severity == "CRITICAL") |
                                "Package: \\(.PkgName) \\(.InstalledVersion)\\nCVE: \\(.VulnerabilityID)\\nFix: \\(.FixedVersion // "No fix available")\\n"' \\
                                ${env.TRIVY_RESULTS} | head -50
                        """
                    }

                    // ---------------------------------------------------------
                    // Write gate report for archiving
                    // ---------------------------------------------------------
                    def gateReport = [
                        timestamp:      new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'"),
                        profile:        env.ACTIVE_PROFILE,
                        branch:         env.GIT_BRANCH,
                        override:       overrideActive,
                        override_reason: params.SECURITY_OVERRIDE_REASON ?: '',
                        results: [
                            sast: [
                                critical: sastCritical,
                                high:     sastHigh,
                                medium:   sastMedium,
                            ],
                            dependency: [
                                critical: depCritical,
                                high:     depHigh,
                                medium:   depMedium,
                            ]
                        ],
                        thresholds: [
                            sast_critical: env.SAST_CRITICAL_THRESHOLD,
                            sast_high:     env.SAST_HIGH_THRESHOLD,
                            dep_critical:  env.DEP_CRITICAL_THRESHOLD,
                            dep_high:      env.DEP_HIGH_THRESHOLD,
                        ],
                        failures: gateFailures,
                        warnings: gateWarnings,
                        status: gateFailures.isEmpty()
                            ? (overrideActive ? 'override' : 'pass')
                            : 'fail',
                    ]

                    writeJSON file: env.GATE_REPORT, json: gateReport, pretty: 2
                    env.GATE_STATUS = gateReport.status

                    // ---------------------------------------------------------
                    // Print gate summary
                    // ---------------------------------------------------------
                    echo """
                    ============================================
                    Security Gate Evaluation
                    ============================================
                    """

                    if (gateWarnings) {
                        gateWarnings.each { echo it }
                    }

                    if (gateFailures) {
                        gateFailures.each { echo it }
                    }

                    echo """
                    ============================================
                    Gate Status: ${gateReport.status.toUpperCase()}
                    ============================================
                    """

                    // ---------------------------------------------------------
                    // Mark build unstable for warnings
                    // ---------------------------------------------------------
                    if (gateWarnings && gateFailures.isEmpty()) {
                        currentBuild.result = 'UNSTABLE'
                    }

                    // ---------------------------------------------------------
                    // Fail the build if gate failed
                    // ---------------------------------------------------------
                    if (!gateFailures.isEmpty() && !overrideActive) {
                        error(
                            "Security Quality Gate FAILED. " +
                            "${gateFailures.size()} threshold(s) exceeded. " +
                            "Fix the issues above and re-run the pipeline."
                        )
                    }

                    if (overrideActive) {
                        echo "⚠️  Gate bypassed via emergency override. " +
                             "Security review required within 24 hours."
                    }
                }
            }

            post {
                always {
                    archiveArtifacts artifacts: """
                        ${env.SAST_RESULTS},
                        ${env.TRIVY_RESULTS},
                        ${env.GATE_REPORT}
                    """,
                    allowEmptyArchive: true,
                    fingerprint: true
                }
            }
        }

        // =====================================================================
        // Stage 5: Build
        // Only reached if security gate passes
        // =====================================================================
        stage('Build') {
            steps {
                echo '🔨 Building application...'
                // Replace with your actual build command:
                // sh 'mvn clean package -DskipTests'
                // sh 'npm run build'
                sh 'echo "Build step - replace with your build command"'
            }
        }

        // =====================================================================
        // Stage 6: Deploy
        // =====================================================================
        stage('Deploy to Staging') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'staging'
                }
            }
            steps {
                echo '🚀 Deploying to staging...'
                sh 'echo "Deploy step - replace with your deploy command"'
            }
        }
    }

    // =========================================================================
    // Post-pipeline notifications
    // =========================================================================
    post {

        always {
            script {
                // Write pipeline summary
                def summary = """
                ============================================
                Pipeline Summary
                ============================================
                Job          : ${env.JOB_NAME} #${env.BUILD_NUMBER}
                Status       : ${currentBuild.currentResult}
                Gate Status  : ${env.GATE_STATUS ?: 'not evaluated'}
                Profile      : ${env.ACTIVE_PROFILE ?: 'unknown'}
                Branch       : ${env.GIT_BRANCH ?: 'unknown'}
                Author       : ${env.GIT_AUTHOR ?: 'unknown'}
                Override     : ${params.SECURITY_OVERRIDE}
                SAST Critical: ${env.SAST_CRITICAL_COUNT ?: '0'}
                SAST High    : ${env.SAST_HIGH_COUNT ?: '0'}
                Dep Critical : ${env.DEP_CRITICAL_COUNT ?: '0'}
                Dep High     : ${env.DEP_HIGH_COUNT ?: '0'}
                Build URL    : ${env.BUILD_URL}
                ============================================
                """
                echo summary
                writeFile file: 'pipeline-summary.txt', text: summary
                archiveArtifacts artifacts: 'pipeline-summary.txt'
            }
        }

        // ---------------------------------------------------------------------
        // Gate failure - notify developer and security team
        // ---------------------------------------------------------------------
        failure {
            script {
                def isGateFailure = env.GATE_STATUS == 'fail'
                def subject = isGateFailure
                    ? "❌ Security Gate Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
                    : "❌ Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}"

                emailext(
                    subject: subject,
                    body: """
                        <h2>${subject}</h2>
                        <table>
                            <tr><td><b>Job</b></td>
                                <td>${env.JOB_NAME}</td></tr>
                            <tr><td><b>Build</b></td>
                                <td>#${env.BUILD_NUMBER}</td></tr>
                            <tr><td><b>Branch</b></td>
                                <td>${env.GIT_BRANCH}</td></tr>
                            <tr><td><b>Author</b></td>
                                <td>${env.GIT_AUTHOR}</td></tr>
                            <tr><td><b>Profile</b></td>
                                <td>${env.ACTIVE_PROFILE}</td></tr>
                            <tr><td><b>SAST Critical</b></td>
                                <td style="color:red">
                                    ${env.SAST_CRITICAL_COUNT ?: '0'}
                                    (threshold: ${env.SAST_CRITICAL_THRESHOLD})
                                </td></tr>
                            <tr><td><b>SAST High</b></td>
                                <td style="color:orange">
                                    ${env.SAST_HIGH_COUNT ?: '0'}
                                    (threshold: ${env.SAST_HIGH_THRESHOLD})
                                </td></tr>
                            <tr><td><b>Dep Critical</b></td>
                                <td style="color:red">
                                    ${env.DEP_CRITICAL_COUNT ?: '0'}
                                    (threshold: ${env.DEP_CRITICAL_THRESHOLD})
                                </td></tr>
                            <tr><td><b>Dep High</b></td>
                                <td style="color:orange">
                                    ${env.DEP_HIGH_COUNT ?: '0'}
                                    (threshold: ${env.DEP_HIGH_THRESHOLD})
                                </td></tr>
                        </table>
                        <p>
                            <a href="${env.BUILD_URL}">View Build</a> |
                            <a href="${env.BUILD_URL}artifact/${env.GATE_REPORT}">
                                Download Gate Report
                            </a>
                        </p>
                        <h3>Next Steps</h3>
                        <ol>
                            <li>Review the scan artifacts for detailed findings</li>
                            <li>Fix critical and high issues</li>
                            <li>Re-run the pipeline</li>
                            <li>If this is blocking a critical hotfix, run with
                                SECURITY_OVERRIDE=true and document the reason</li>
                        </ol>
                    """,
                    to:           "${env.DEV_EMAIL}, ${env.SECURITY_EMAIL}",
                    mimeType:     'text/html',
                    attachmentsPattern: "${env.GATE_REPORT}"
                )

                // Slack notification
                slackSend(
                    color:   'danger',
                    message: "❌ Security Gate Failed: ${env.JOB_NAME} " +
                             "#${env.BUILD_NUMBER} | " +
                             "SAST Critical: ${env.SAST_CRITICAL_COUNT ?: 0} | " +
                             "Dep Critical: ${env.DEP_CRITICAL_COUNT ?: 0} | " +
                             "<${env.BUILD_URL}|View Build>"
                )
            }
        }

        // ---------------------------------------------------------------------
        // Warnings (medium findings exceeded threshold)
        // ---------------------------------------------------------------------
        unstable {
            emailext(
                subject: "⚠️ Security Warnings: " +
                         "${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2>Security Warnings Detected</h2>
                    <p>The pipeline passed but security warnings were detected.</p>
                    <table>
                        <tr><td><b>SAST Medium</b></td>
                            <td>${env.SAST_MEDIUM_COUNT ?: '0'}</td></tr>
                        <tr><td><b>Dep Medium</b></td>
                            <td>${env.DEP_MEDIUM_COUNT ?: '0'}</td></tr>
                    </table>
                    <p>These should be addressed in the next sprint.</p>
                    <p><a href="${env.BUILD_URL}">View Build</a></p>
                """,
                to:       env.DEV_EMAIL,
                mimeType: 'text/html'
            )

            slackSend(
                color:   'warning',
                message: "⚠️ Security Warnings: ${env.JOB_NAME} " +
                         "#${env.BUILD_NUMBER} | " +
                         "SAST Medium: ${env.SAST_MEDIUM_COUNT ?: 0} | " +
                         "Dep Medium: ${env.DEP_MEDIUM_COUNT ?: 0} | " +
                         "<${env.BUILD_URL}|View Build>"
            )
        }

        // ---------------------------------------------------------------------
        // Recovery notification
        // ---------------------------------------------------------------------
        fixed {
            emailext(
                subject: "✅ Security Gate Recovered: " +
                         "${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2>Pipeline Recovered</h2>
                    <p>The security gate is now passing after previous failures.</p>
                    <p><a href="${env.BUILD_URL}">View Build</a></p>
                """,
                to:       "${env.DEV_EMAIL}, ${env.SECURITY_EMAIL}",
                mimeType: 'text/html'
            )

            slackSend(
                color:   'good',
                message: "✅ Security Gate Recovered: ${env.JOB_NAME} " +
                         "#${env.BUILD_NUMBER} | " +
                         "<${env.BUILD_URL}|View Build>"
            )
        }
    }
}
