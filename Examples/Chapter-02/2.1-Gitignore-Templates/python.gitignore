# ============================================
# SECURITY-SPECIFIC (Python)
# ============================================
# Django secret key
**/secret_key.txt
**/django_secret_key

# Database credentials
**/database.ini
**/db_config.py

# API keys
**/api_keys.py
**/credentials.py

# AWS credentials
.aws/
**/boto.cfg

# Google Cloud credentials
**/gcp-key*.json
**/service-account*.json

# SSL certificates
*.pem
*.key
*.crt

# OAuth secrets
**/oauth_credentials.json
**/client_secrets.json

# Stripe keys
**/stripe_keys.py

# SendGrid keys
**/sendgrid_key.txt
