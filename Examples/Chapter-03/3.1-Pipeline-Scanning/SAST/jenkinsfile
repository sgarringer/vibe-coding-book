// =============================================================================
// Jenkinsfile - Security-Integrated CI/CD Pipeline
// Book Reference: Chapter 3, Section 3.1.2.2
// =============================================================================
// Features demonstrated:
//   - SAST with Semgrep
//   - Quality gates
//   - Email notifications
//   - Pipeline integration
// =============================================================================

pipeline {
    agent any

    // -------------------------------------------------------------------------
    // Environment variables
    // -------------------------------------------------------------------------
    environment {
        // Semgrep token for Semgrep Cloud Platform (optional)
        // Configure in Jenkins: Manage Jenkins > Credentials
        SEMGREP_APP_TOKEN = credentials('semgrep-app-token')

        // Notification recipients
        SECURITY_EMAIL   = 'security-team@yourcompany.com'
        DEV_EMAIL        = "${env.CHANGE_AUTHOR_EMAIL ?: 'dev-team@yourcompany.com'}"

        // Thresholds - adjust to match your risk tolerance
        // Principle: Fail Fast - block on critical, warn on high
        CRITICAL_THRESHOLD = 0    // Block build if critical findings exceed this
        HIGH_THRESHOLD     = 5    // Warn if high findings exceed this

        // Artifact paths
        RESULTS_JSON = 'semgrep-results.json'
        RESULTS_SARIF = 'semgrep-results.sarif'
    }

    // -------------------------------------------------------------------------
    // Pipeline options
    // -------------------------------------------------------------------------
    options {
        // Keep last 10 builds
        buildDiscarder(logRotator(numToKeepStr: '10'))
        // Timeout the entire pipeline after 1 hour
        timeout(time: 1, unit: 'HOURS')
        // Add timestamps to console output
        timestamps()
        // Prevent concurrent builds on the same branch
        disableConcurrentBuilds()
    }

    // -------------------------------------------------------------------------
    // Trigger configuration
    // -------------------------------------------------------------------------
    triggers {
        // Poll SCM every 5 minutes (replace with webhooks in production)
        pollSCM('H/5 * * * *')
    }

    stages {

        // =====================================================================
        // Stage 1: Checkout
        // =====================================================================
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    // Capture git metadata for notifications
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()
                }
            }
        }

        // =====================================================================
        // Stage 2: SAST - Static Application Security Testing
        // Principle: Shift Left - runs before build to catch issues early
        // =====================================================================
        stage('SAST - Semgrep') {
            agent {
                docker {
                    image 'returntocorp/semgrep:latest'
                    // Run as non-root for security
                    args '--user root'
                    reuseNode true
                }
            }

            steps {
                echo '🔍 Running Semgrep SAST scan...'

                // -------------------------------------------------------------
                // Run Semgrep scan
                // continue-on-error so we can archive results before failing
                // -------------------------------------------------------------
                sh '''
                    semgrep scan \
                        --config=auto \
                        --config=p/security-audit \
                        --config=p/owasp-top-ten \
                        --json \
                        --output=${RESULTS_JSON} \
                        --sarif \
                        --sarif-output=${RESULTS_SARIF} \
                        --verbose \
                        || true
                '''

                // -------------------------------------------------------------
                // Parse results and set environment variables
                // -------------------------------------------------------------
                script {
                    def results = readJSON file: env.RESULTS_JSON

                    env.CRITICAL_COUNT = results.results
                        .findAll { it.extra?.severity == 'ERROR' }
                        .size()
                        .toString()

                    env.HIGH_COUNT = results.results
                        .findAll { it.extra?.severity == 'WARNING' }
                        .size()
                        .toString()

                    env.INFO_COUNT = results.results
                        .findAll { it.extra?.severity == 'INFO' }
                        .size()
                        .toString()

                    env.TOTAL_COUNT = results.results.size().toString()

                    echo """
                    ============================================
                    Semgrep Scan Results
                    ============================================
                    Critical : ${env.CRITICAL_COUNT}
                    High     : ${env.HIGH_COUNT}
                    Info     : ${env.INFO_COUNT}
                    Total    : ${env.TOTAL_COUNT}
                    ============================================
                    """
                }
            }

            // Archive results regardless of outcome
            post {
                always {
                    archiveArtifacts artifacts: "${RESULTS_JSON}, ${RESULTS_SARIF}",
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        // =====================================================================
        // Stage 3: Quality Gate
        // Principle: Fail Fast - evaluate thresholds and block if exceeded
        // Principle: Provide Context - give developers actionable output
        // =====================================================================
        stage('Security Quality Gate') {
            steps {
                script {
                    def criticalCount = env.CRITICAL_COUNT.toInteger()
                    def highCount     = env.HIGH_COUNT.toInteger()
                    def passed        = true

                    // ---------------------------------------------------------
                    // Print detailed findings for developer context
                    // ---------------------------------------------------------
                    if (criticalCount > 0) {
                        echo '🔴 CRITICAL FINDINGS:'
                        def results = readJSON file: env.RESULTS_JSON
                        results.results
                            .findAll { it.extra?.severity == 'ERROR' }
                            .each { finding ->
                                echo """
                                  Rule    : ${finding.check_id}
                                  File    : ${finding.path}:${finding.start.line}
                                  Message : ${finding.extra?.message}
                                """
                            }
                    }

                    // ---------------------------------------------------------
                    // Evaluate quality gate thresholds
                    // ---------------------------------------------------------
                    if (criticalCount > env.CRITICAL_THRESHOLD.toInteger()) {
                        echo "❌ Quality Gate FAILED: ${criticalCount} critical finding(s) " +
                             "exceeds threshold of ${env.CRITICAL_THRESHOLD}"
                        passed = false
                    }

                    if (highCount > env.HIGH_THRESHOLD.toInteger()) {
                        echo "⚠️  Quality Gate WARNING: ${highCount} high finding(s) " +
                             "exceeds threshold of ${env.HIGH_THRESHOLD}"
                        // Warn but don't block for high findings
                        // Adjust this to 'passed = false' for stricter enforcement
                        currentBuild.result = 'UNSTABLE'
                    }

                    if (!passed) {
                        error("Security Quality Gate failed. " +
                              "Fix critical issues before merging.")
                    }

                    echo '✅ Security Quality Gate PASSED'
                }
            }
        }

        // =====================================================================
        // Stage 4: Build
        // Only reached if security gate passes
        // =====================================================================
        stage('Build') {
            steps {
                echo '🔨 Building application...'
                // Replace with your actual build command:
                // sh 'mvn clean package -DskipTests'
                // sh 'npm run build'
                // sh 'docker build -t myapp:${GIT_COMMIT} .'
                sh 'echo "Build step - replace with your build command"'
            }
        }

        // =====================================================================
        // Stage 5: Test
        // =====================================================================
        stage('Test') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        echo '🧪 Running unit tests...'
                        // sh 'mvn test'
                        // sh 'npm test'
                        sh 'echo "Test step - replace with your test command"'
                    }
                }
                stage('Dependency Scan') {
                    steps {
                        echo '📦 Scanning dependencies...'
                        // Trivy for container/dependency scanning
                        // sh 'trivy fs --exit-code 1 --severity CRITICAL .'
                        sh 'echo "Dependency scan - replace with Trivy or similar"'
                    }
                }
            }
        }

        // =====================================================================
        // Stage 6: Deploy to Staging
        // =====================================================================
        stage('Deploy to Staging') {
            when {
                branch 'develop'
            }
            steps {
                echo '🚀 Deploying to staging...'
                // sh './deploy.sh staging'
                sh 'echo "Deploy to staging - replace with your deploy command"'
            }
        }

        // =====================================================================
        // Stage 7: Deploy to Production
        // Requires manual approval
        // =====================================================================
        stage('Deploy to Production') {
            when {
                branch 'main'
            }
            steps {
                // Manual approval gate before production deployment
                input message: 'Deploy to production?',
                      ok: 'Deploy',
                      submitter: 'release-managers'

                echo '🚀 Deploying to production...'
                // sh './deploy.sh production'
                sh 'echo "Deploy to production - replace with your deploy command"'
            }
        }
    }

    // =========================================================================
    // Post-pipeline actions
    // Principle: Provide Context - notify the right people with the right info
    // =========================================================================
    post {

        // Always archive the scan summary
        always {
            script {
                def summary = """
                Pipeline   : ${env.JOB_NAME} #${env.BUILD_NUMBER}
                Status     : ${currentBuild.currentResult}
                Branch     : ${env.BRANCH_NAME ?: 'unknown'}
                Author     : ${env.GIT_AUTHOR ?: 'unknown'}
                Commit     : ${env.GIT_COMMIT_MSG ?: 'unknown'}
                Critical   : ${env.CRITICAL_COUNT ?: '0'}
                High       : ${env.HIGH_COUNT ?: '0'}
                Build URL  : ${env.BUILD_URL}
                """
                echo summary
                writeFile file: 'pipeline-summary.txt', text: summary
                archiveArtifacts artifacts: 'pipeline-summary.txt'
            }
        }

        // Send email on failure with full context
        failure {
            emailext(
                subject: "🚨 Security Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2>Security Pipeline Failed</h2>
                    <table>
                        <tr><td><b>Job</b></td><td>${env.JOB_NAME}</td></tr>
                        <tr><td><b>Build</b></td><td>#${env.BUILD_NUMBER}</td></tr>
                        <tr><td><b>Branch</b></td><td>${env.BRANCH_NAME}</td></tr>
                        <tr><td><b>Author</b></td><td>${env.GIT_AUTHOR}</td></tr>
                        <tr><td><b>Critical Findings</b></td>
                            <td style="color:red">${env.CRITICAL_COUNT}</td></tr>
                        <tr><td><b>High Findings</b></td>
                            <td style="color:orange">${env.HIGH_COUNT}</td></tr>
                    </table>
                    <p>
                        <a href="${env.BUILD_URL}">View Build</a> |
                        <a href="${env.BUILD_URL}artifact/${RESULTS_JSON}">
                            Download Results
                        </a>
                    </p>
                    <p>Review the scan results and fix critical issues before re-running.</p>
                """,
                to: "${env.DEV_EMAIL}, ${env.SECURITY_EMAIL}",
                mimeType: 'text/html',
                attachmentsPattern: "${RESULTS_JSON}"
            )
        }

        // Send success notification on recovery (was failing, now passing)
        fixed {
            emailext(
                subject: "✅ Security Pipeline Recovered: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2>Pipeline Recovered</h2>
                    <p>The security pipeline is now passing after previous failures.</p>
                    <p><a href="${env.BUILD_URL}">View Build</a></p>
                """,
                to: "${env.DEV_EMAIL}, ${env.SECURITY_EMAIL}",
                mimeType: 'text/html'
            )
        }

        // Unstable = high findings exceeded threshold
        unstable {
            emailext(
                subject: "⚠️ Security Warning: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <h2>Security Warnings Detected</h2>
                    <p>The pipeline passed but ${env.HIGH_COUNT} high-severity
                    findings were detected.</p>
                    <p><a href="${env.BUILD_URL}">View Build</a></p>
                """,
                to: "${env.DEV_EMAIL}",
                mimeType: 'text/html'
            )
        }
    }
}
