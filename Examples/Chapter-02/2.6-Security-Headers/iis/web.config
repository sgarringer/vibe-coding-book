<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config — Security Headers for IIS
  Place in the root of your web application.
-->
<configuration>
  <system.webServer>

    <httpProtocol>
      <customHeaders>

        <!-- Strict-Transport-Security -->
        <!-- Only effective over HTTPS. Remove preload until ready. -->
        <add name="Strict-Transport-Security"
             value="max-age=31536000; includeSubDomains; preload" />

        <!-- X-Frame-Options -->
        <add name="X-Frame-Options" value="DENY" />

        <!-- X-Content-Type-Options -->
        <add name="X-Content-Type-Options" value="nosniff" />

        <!-- Referrer-Policy -->
        <add name="Referrer-Policy"
             value="strict-origin-when-cross-origin" />

        <!-- Permissions-Policy -->
        <add name="Permissions-Policy"
             value="geolocation=(), microphone=(), camera=()" />

        <!--
          Content-Security-Policy
          Baseline policy — tune for your application.
          See chapter-02/headers/csp/ for full CSP examples.
          Start with Report-Only (see Section 2.6.3.1), then switch to enforcing.
        -->
        <add name="Content-Security-Policy"
             value="default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; connect-src 'self'; font-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self';" />

        <!-- Remove headers that leak server information -->
        <remove name="X-Powered-By" />

      </customHeaders>
    </httpProtocol>

    <!-- Remove the Server header (requires URL Rewrite module) -->
    <rewrite>
      <outboundRules>
        <rule name="Remove Server header">
          <match serverVariable="RESPONSE_Server" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
      </outboundRules>
    </rewrite>

  </system.webServer>
</configuration>
