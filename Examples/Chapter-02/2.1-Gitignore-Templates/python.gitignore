# ============================================
# PYTHON .GITIGNORE
# ============================================
# Security-focused template for Python projects
# ============================================

# ============================================
# BYTE-COMPILED / OPTIMIZED
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================
# DISTRIBUTION / PACKAGING
# ============================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# VIRTUAL ENVIRONMENTS
# ============================================
venv/
ENV/
env/
.venv/
.ENV/
.env/

# ============================================
# TESTING
# ============================================
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
.hypothesis/

# ============================================
# JUPYTER NOTEBOOK
# ============================================
.ipynb_checkpoints
*.ipynb

# ============================================
# ENVIRONMENT VARIABLES
# ============================================
.env
.env.*
!.env.example
.flaskenv

# ============================================
